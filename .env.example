# =============================================================================
# Contract360 — environment variable template
#
# Copy this file to .env and fill in every value before starting the server.
# Variables marked REQUIRED will cause a startup error if left empty.
# =============================================================================


# =============================================================================
# Artifact storage
# REQUIRED in production — set to true so the server uses Azure Blob Storage
# instead of local disk. Always true when deploying to Azure Container Apps.
# =============================================================================
USE_BLOB_ARTIFACTS=true


# =============================================================================
# Azure OpenAI  (chat + embeddings)       REQUIRED
# =============================================================================
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_API_VERSION=2024-10-21

# Deployment names (must exist in your Azure OpenAI resource)
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4-1-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Set to true to use Azure OpenAI for embeddings at ingestion time.
# false = lightweight local model (lower quality, no Azure cost).
USE_AZURE_OPENAI_EMBEDDINGS=true


# =============================================================================
# Azure AI Search                          REQUIRED
# =============================================================================
AZURE_SEARCH_ENDPOINT=https://<your-resource>.search.windows.net
AZURE_SEARCH_ADMIN_KEY=<your-admin-key>
AZURE_SEARCH_INDEX=contract-knowledge-index
AZURE_SEARCH_VECTOR_DIMENSIONS=1536


# =============================================================================
# Azure Blob Storage                       REQUIRED
# =============================================================================
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER=contract360-artifacts


# =============================================================================
# Azure Cosmos DB NoSQL  (chat history, ingest jobs)   REQUIRED
# =============================================================================
COSMOS_NOSQL_ENDPOINT=https://<your-account>.documents.azure.com:443/
COSMOS_NOSQL_KEY=<your-key>
COSMOS_NOSQL_DATABASE=contract360


# =============================================================================
# Azure Cosmos DB for Apache Gremlin  (knowledge graph)
# Leave all GREMLIN_* variables empty to disable graph/hybrid RAG routes;
# the server falls back to tree-only search when Gremlin is not configured.
# =============================================================================
GREMLIN_ENDPOINT=<your-account>.gremlin.cosmos.azure.com
GREMLIN_DATABASE=contract360
GREMLIN_GRAPH=knowledge-graph
GREMLIN_USERNAME=/dbs/contract360/colls/knowledge-graph
GREMLIN_PASSWORD=<your-primary-key>

# Application-level tenant/workspace identifier — used as the Gremlin partition key.
TENANT_ID=contract360-prod


# =============================================================================
# CORS — allowed frontend origins (comma-separated)
# Set to the URL of your deployed frontend container.
# Example: https://contract360-ui.azurecontainerapps.io
# =============================================================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000


# =============================================================================
# Azure Document Intelligence  (optional — improves PDF parsing quality)
# =============================================================================
USE_AZURE_DOCUMENT_INTELLIGENCE=false
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=<your-key>


# =============================================================================
# PageIndex API  (optional — improves contract structure extraction)
# =============================================================================
USE_PAGEINDEX_API=false
PAGEINDEX_API_KEY=<your-key>
PAGEINDEX_POLL_SECONDS=10
PAGEINDEX_MAX_POLLS=60


# =============================================================================
# KG extraction tuning  (optional)
# =============================================================================
KG_EXTRACTION_LIMIT=20
KG_MIN_CLAUSE_CHARS=80
KG_MAX_CLAUSE_CHARS=3000
KG_DRY_RUN=false
