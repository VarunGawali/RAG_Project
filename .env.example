# PageIndex API mode
USE_PAGEINDEX_API=
PAGEINDEX_API_KEY=
PAGEINDEX_POLL_SECONDS=
PAGEINDEX_MAX_POLLS=

# Azure OpenAI embeddings
USE_AZURE_OPENAI_EMBEDDINGS=


AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_CHAT_DEPLOYMENT=


USE_AZURE_DOCUMENT_INTELLIGENCE=
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_ADMIN_KEY=
AZURE_SEARCH_INDEX=
AZURE_SEARCH_VECTOR_DIMENSIONS=


# Azure Blob Storage — raw file and artifact persistence
# Use the "Connection string" from your Storage Account → Access Keys page.
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=contract360-artifacts

# Set to true in production (Azure App Service / Container Apps).
# False keeps all artifacts on local disk for development/testing.
# When true, run `python -m app.scripts.upload_artifacts_to_blob` once
# to migrate existing local KG JSONs and processed artifacts to Blob.
USE_BLOB_ARTIFACTS=false

# Cosmos DB NoSQL — chat history
# Create a Cosmos DB account (Core/NoSQL API) and paste the credentials below.
# The database and container are created automatically on first run.
COSMOS_NOSQL_ENDPOINT=
COSMOS_NOSQL_KEY=
COSMOS_NOSQL_DATABASE=contract360

# Cosmos Gremlin — knowledge graph
GREMLIN_ENDPOINT=
GREMLIN_DATABASE=
GREMLIN_GRAPH=
GREMLIN_USERNAME=
GREMLIN_PASSWORD=

# App partition key value
TENANT_ID=
